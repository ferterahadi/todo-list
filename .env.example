# ---------------------------------------------------------------------------
# TODO_HUB — where your project hub lives.
#
# The plugin creates the hub here on first run (default ~/todo) and the /todo-*
# skills resolve every hub path (index.md, each project's plan.md / tasks.md)
# against this root, so they keep working even when a skill is invoked from
# inside another repo.
#
# To use a location other than ~/todo, set this in your user-level Claude Code
# config (e.g. ~/.claude/CLAUDE.md or your shell profile) BEFORE first run, so
# the bootstrap hook seeds the hub in the right place.
# ---------------------------------------------------------------------------
TODO_HUB=~/todo

# ---------------------------------------------------------------------------
# Verification MCP (OPTIONAL) — the "check" gate used by /todo-verify.
#
# /todo-verify is pluggable: it drives ANY MCP server that can start a run
# against a named feature/target and report pass/fail, plus optional coverage.
# Point it at your own test harness — see skills/todo-verify/SKILL.md for the
# exact contract (start_run / wait_for_result / get_result / get_coverage).
#
# If you have no such server, projects simply omit the "## Verification" block
# in plan.md and the plan -> do -> revise loop runs without a check gate.
#
# There is no required env var here — configure your MCP server through your
# Claude Code MCP settings, not this file. Any server matching the contract
# documented in skills/todo-verify/SKILL.md works.
# ---------------------------------------------------------------------------
